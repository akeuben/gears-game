    "globalActivities": [
        {
            "type": "dangerous_eval",
            "bindingInputs": ["a", "b", "c"],
            "defaultInputValues": {
                "a": "0",
                "b": "0",
                "c": "0"
            },
            "function": "return \"\" + (parseInt(a.replace(/\\D/g,'')) + parseInt(b.replace(/\\D/g,'')) + parseInt(c.replace(/\\D/g,'')));",
            "bindings": {
                "provides": {
                    "result": "channel4"
