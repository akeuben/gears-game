                "recieves": {
                    "a": "channel1a",
                    "b": "channel2a",
                    "c": "channel3a"
                }
            }
        },
        {
            "type": "dangerous_eval",
            "bindingInputs": [
                "other",
                "living_essentials",
                "postsecondary",
                "annual_expenses",
                "budget"
            ],
            "defaultInputValues": {
                "other": "0",
                "living_essentials": "0",
                "postsecondary": "0",
                "annual_expenses": "0",
                "budget": "0"
            },
            "function": "return \"\" + (parseInt(budget.replace(/\\D/g,'')) - parseInt(other.replace(/\\D/g,'')) - parseInt(living_essentials.replace(/\\D/g,'')) - parseInt(postsecondary.replace(/\\D/g,'')) - parseInt(annual_expenses.replace(/\\D/g,'')));",
            "bindings": {
                "provides": {
                    "result": "remaining_balance"
                },
