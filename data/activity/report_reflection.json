                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Quiet Workspace\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Breaks when needed"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Extra time for tests and quizzes\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Extra time for tests and quizzes"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Help form teachers outside of class time.\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Help form teachers outside of class time."
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Break down of tasks into smaller parts\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Break down of tasks into smaller parts"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Materials provided prior to class\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Materials provided prior to class"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Classroom notes provided\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Classroom notes provided"
                                }
                            }
                        }
                    }
                ]
            },
            {
                "type": "reflection",
                "number": "5",
                "prompt": "Other than accommodations, think about what teachers do that help you. What do you find helpful?"
            }
        ]
    ]
