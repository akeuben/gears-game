                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Speech-to-text software\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Speech-to-text software"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Spell checking software\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Spell checking software"
                                }
                            }
                        }
                    },
                    {
                        "element": {
                            "type": "scale",
                            "prompt": "On a scale of 1-10, with 10 being most helpful, how appropriate is \"Alternate ways for assessment\" for your learning needs?",
                            "bindings": {
                                "recieves": {
                                    "visible": "Alternate ways for assessment"
                                }
