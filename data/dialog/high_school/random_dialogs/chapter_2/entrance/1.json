[
    {
        "type": "message",
        "source": "%player%",
        "message": "Hey Marcus, how’s it going?",
        "setCharacter": "Marcus"
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "Hey %player%! I’m good, how about you?"
    },
    {
        "type": "message",
        "source": "%player%",
        "message": "I'm just a bit hungry, and I'm planning on eating out but I'm tired of the same old restaurants. What’s your favorite restaurant of all time? I need to try something new."
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "Oh, definitely Savory Delights in the Mall."
    },
    {
        "type": "message",
        "source": "%player%",
        "message": "That sounds amazing! I’ll have to try it. I can't believe I've never been there. I like the bakery in that mall. Have you been there?"
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "Yes, that bakery is nice. I like their sweet breads and their cakes."
    },
    {
        "type": "message",
        "source": "%player%",
        "message": "My favorite cake to get there is chocolate. What about you?"
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "I love their red velvet cake."
    },
    {
        "type": "message",
        "source": "%player%",
        "message": "Red velvet, nice choice! I love Riverside Mall, there's so many great things in it."
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "Yeah, that mall is amazing. Did you hear there's a new store opening there? I need to go shopping; I could use a new hoodie."
    },
    {
        "type": "message",
        "source": "%player%",
        "message": "A new hoodie sounds great! I'll check out the new store too. Thanks for the tips!"
    },
    {
        "type": "message",
        "source": "Marcus",
        "message": "No problem! See you around, %player%."
    },
